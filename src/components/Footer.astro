---
import { messagesByLocale } from "../i18n/locales";
const t = messagesByLocale.es.footer;
---

<footer class="site-footer">
  <div class="footer-shell">
    <section class="footer-top">
      <div class="footer-brand">
        <a
          href="/"
          class="footer-logo-link"
          aria-label={t.logoHomeLabel}
          data-i18n-attr="aria-label:footer.logoHomeLabel"
        >
          <img src="/gocapital_logo.png" alt="GoCapital" class="footer-logo" />
        </a>

        <nav aria-label={t.navLabel} data-i18n-attr="aria-label:footer.navLabel">
          <ul class="footer-links">
            <li><a href="#" data-i18n="footer.links.careers">{t.links.careers}</a></li>
            <li><a href="#" data-i18n="footer.links.about">{t.links.about}</a></li>
            <li><a href="#" data-i18n="footer.links.alumni">{t.links.alumni}</a></li>
            <li><a href="/contacto" data-i18n="footer.links.contact">{t.links.contact}</a></li>
            <li><a href="#" data-i18n="footer.links.locations">{t.links.locations}</a></li>
          </ul>
        </nav>
      </div>

      <div class="footer-subscribe">
        <h2 data-i18n="footer.subscribeTitle">{t.subscribeTitle}</h2>
        <p data-i18n="footer.subscribeCopy">{t.subscribeCopy}</p>
        <form class="subscribe-form" action="#" method="post">
          <label class="sr-only" for="footer-email" data-i18n="footer.emailLabel">{t.emailLabel}</label>
          <input
            id="footer-email"
            name="email"
            type="email"
            placeholder={t.emailPlaceholder}
            required
            data-i18n-attr="placeholder:footer.emailPlaceholder"
          />
          <button type="submit" data-i18n="footer.submit">{t.submit}</button>
        </form>
      </div>
    </section>

    <section class="footer-middle">
      <ul class="social-list" aria-label={t.socialLabel} data-i18n-attr="aria-label:footer.socialLabel">
        <li><a href="#" aria-label="LinkedIn">in</a></li>
        <li><a href="#" aria-label="X">x</a></li>
        <li><a href="#" aria-label="Facebook">f</a></li>
        <li><a href="#" aria-label="YouTube">yt</a></li>
        <li><a href="#" aria-label="RSS">rss</a></li>
      </ul>

      <ul class="legal-links">
        <li><a href="#" data-i18n="footer.legalLinks.scam">{t.legalLinks.scam}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.faq">{t.legalLinks.faq}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.privacy">{t.legalLinks.privacy}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.choices">{t.legalLinks.choices}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.cookie">{t.legalLinks.cookie}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.terms">{t.legalLinks.terms}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.language">{t.legalLinks.language}</a></li>
        <li><a href="#" data-i18n="footer.legalLinks.accessibility">{t.legalLinks.accessibility}</a></li>
      </ul>
    </section>

    <section class="footer-bottom">
      <p data-i18n="footer.insightsCopy">{t.insightsCopy}</p>
      <p data-i18n="footer.copyright">{t.copyright}</p>
    </section>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    color: var(--text);
  }

  .footer-shell {
    width: min(1200px, 100% - 2rem);
    margin: 0 auto;
    padding: clamp(2.2rem, 4vw, 3.25rem) 0 1.4rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 2rem;
  }

  .footer-logo {
    width: clamp(9rem, 16vw, 12rem);
    height: auto;
    display: block;
  }

  .footer-logo-link {
    display: inline-block;
    margin-bottom: 1.2rem;
  }

  .footer-links,
  .social-list,
  .legal-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, max-content));
    gap: 0.95rem 2rem;
  }

  .footer-links a,
  .legal-links a {
    color: var(--text);
    text-decoration: none;
  }

  .footer-links a:hover,
  .legal-links a:hover {
    color: var(--primary);
  }

  .footer-subscribe h2 {
    margin: 0;
    font-size: 2rem;
  }

  .footer-subscribe p {
    margin: 0.6rem 0 1rem;
    color: var(--muted);
  }

  .subscribe-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.65rem;
  }

  .subscribe-form input {
    min-height: 3rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 88%, var(--bg) 12%);
    color: var(--text);
    padding: 0 0.9rem;
    font: inherit;
  }

  .subscribe-form button {
    min-height: 3rem;
    border: 1px solid var(--primary);
    background: var(--primary);
    color: #fff;
    font: inherit;
    padding: 0 1.25rem;
    cursor: pointer;
  }

  .subscribe-form button:hover {
    background: color-mix(in srgb, var(--primary) 85%, #fff 15%);
  }

  .footer-middle {
    margin-top: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.2rem 2rem;
    align-items: start;
  }

  .social-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .social-list a {
    width: 2.2rem;
    height: 2.2rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    text-decoration: none;
    background: var(--text);
    color: var(--surface);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .social-list a:hover {
    background: var(--primary);
  }

  .legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.5rem;
  }

  .footer-bottom {
    margin-top: 1.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.2rem;
    justify-content: space-between;
    color: var(--muted);
  }

  .footer-bottom p {
    margin: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 920px) {
    .footer-top {
      grid-template-columns: 1fr;
    }

    .footer-links {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .footer-middle {
      grid-template-columns: 1fr;
    }

    .subscribe-form {
      grid-template-columns: 1fr;
    }
  }
</style>
