---
const featuredVideo = {
  id: "NyIA4REQYNk",
  date: "Marzo 2, 2026",
  title: "No te pierdas la estrategia de crecimiento para 2026",
  description:
    "Un resumen practico de decisiones de inversion, foco operativo y tecnologia para escalar con disciplina.",
};

const videos = [
  {
    id: "NyIA4REQYNk",
    title: "Estrategia de crecimiento para 2026",
  },
  {
    id: "M7lc1UVf-VE",
    title: "Planeacion financiera para empresas",
  },
  {
    id: "ysz5S6PUM-U",
    title: "IA aplicada al negocio",
  },
];
---

<section class="videos" aria-labelledby="videos-title">
  <div class="videos-shell">
    <div class="videos-head">
      <div>
        <p class="videos-kicker">VIDEOS</p>
        <h2 id="videos-title">Contenido en YouTube para decisiones mas claras</h2>
        <p class="videos-copy">
          En lugar de podcast, aqui mostramos una seleccion de videos con ideas accionables sobre estrategia,
          inversion y transformacion.
        </p>
      </div>
      <a class="videos-cta" href="https://www.youtube.com/" target="_blank" rel="noreferrer">
        Ver canal >
      </a>
    </div>

    <article class="featured-video">
      <div class="featured-copy">
        <p class="featured-date">{featuredVideo.date}</p>
        <h3>{featuredVideo.title}</h3>
        <p>{featuredVideo.description}</p>
      </div>
      <div class="featured-player">
        <iframe
          src={`https://www.youtube.com/embed/${featuredVideo.id}`}
          title={featuredVideo.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
    </article>

    <div class="videos-grid">
      {
        videos.map((video) => (
          <article class="video-card">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
            <h3>{video.title}</h3>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .videos {
    padding: clamp(3rem, 6vw, 6rem) 1rem;
    background: linear-gradient(110deg, #06224a 0%, #123fa7 100%);
    color: #eff4ff;
  }

  .videos-shell {
    width: min(1200px, 100%);
    margin: 0 auto;
  }

  .videos-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem 1.5rem;
    align-items: center;
    margin-bottom: 2rem;
  }

  .videos-kicker {
    margin: 0;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #c9d9ff;
  }

  .videos h2 {
    margin: 0.75rem 0 0;
    font-size: clamp(2rem, 4.6vw, 4rem);
    line-height: 1.08;
    font-weight: 500;
  }

  .videos-copy {
    margin: 1rem 0 0;
    max-width: 68ch;
    color: #d7e5ff;
    line-height: 1.6;
    font-size: 1.1rem;
  }

  .videos-cta {
    justify-self: end;
    color: #eff4ff;
    text-decoration: none;
    border: 1px solid rgba(239, 244, 255, 0.6);
    padding: 0.85rem 1.4rem;
    border-radius: 0.65rem;
    transition: background-color 200ms ease, border-color 200ms ease;
  }

  .videos-cta:hover,
  .videos-cta:focus-visible {
    background: rgba(239, 244, 255, 0.12);
    border-color: #eff4ff;
  }

  .featured-video {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    background: rgba(3, 16, 45, 0.4);
    border: 1px solid rgba(208, 224, 255, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 1.2rem;
  }

  .featured-copy {
    padding: clamp(1.2rem, 3.4vw, 2.4rem);
    background: #eef2fa;
    color: #0d1a36;
  }

  .featured-date {
    margin: 0;
    font-size: 0.95rem;
    color: #4f5a74;
  }

  .featured-copy h3 {
    margin: 0.8rem 0;
    font-size: clamp(1.7rem, 3.2vw, 3rem);
    line-height: 1.08;
  }

  .featured-copy p {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .featured-player {
    aspect-ratio: 16 / 9;
    min-height: 320px;
    background: #061d47;
  }

  .featured-player iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .video-card {
    background: rgba(6, 24, 58, 0.62);
    border: 1px solid rgba(219, 231, 255, 0.24);
    border-radius: 0.85rem;
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .video-card iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    display: block;
  }

  .video-card h3 {
    margin: 0;
    padding: 0.95rem 0.95rem 1.1rem;
    color: #eff4ff;
    font-size: 1.06rem;
    line-height: 1.35;
  }

  .video-card:hover,
  .video-card:focus-within {
    transform: translateY(-4px);
    border-color: rgba(200, 161, 74, 0.88);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.26);
  }

  @media (max-width: 960px) {
    .videos-head {
      grid-template-columns: 1fr;
    }

    .videos-cta {
      justify-self: start;
    }

    .featured-video {
      grid-template-columns: 1fr;
    }

    .featured-player {
      min-height: 240px;
    }

    .videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
