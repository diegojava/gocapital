---
import { messagesByLocale } from "../i18n/locales";

const videoId = "NyIA4REQYNk";
const videoUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&controls=0&loop=1&playlist=${videoId}&modestbranding=1&playsinline=1&rel=0`;
const t = messagesByLocale.es.shared;
---

<section class="video-hero" aria-label={t.videoHeroAriaLabel} data-i18n-attr="aria-label:shared.videoHeroAriaLabel">
  <div class="video-shell">
    <iframe
      src={videoUrl}
      title={t.videoHeroTitle}
      data-i18n-attr="title:shared.videoHeroTitle"
      loading="eager"
      allow="autoplay; encrypted-media; picture-in-picture"
      allowfullscreen
      referrerpolicy="strict-origin-when-cross-origin"
    ></iframe>
  </div>
</section>

<style>
  .video-hero {
    width: 100%;
    min-height: calc(100vh - 5rem);
    overflow: hidden;
    background: #000;
  }

  .video-shell {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: calc(100vh - 5rem);
  }

  .video-shell iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    border: 0;
    width: 177.78vh;
    height: 56.25vw;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
  }

  @media (max-width: 899px) {
    .video-hero,
    .video-shell {
      min-height: calc(100vh - 4.5rem);
    }
  }
</style>
