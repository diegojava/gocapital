---
import BaseLayout from "../layouts/BaseLayout.astro";
import { messagesByLocale } from "../i18n/locales";

const t = messagesByLocale.es.contactoPage;
const wasSubmitted = Astro.url.searchParams.get("enviado") === "true";
---

<BaseLayout title={t.title} titleKey="contactoPage.title">
  <section class="contact-hero">
    <p class="kicker" data-i18n="contactoPage.hero.kicker">{t.hero.kicker}</p>
    <h1 data-i18n="contactoPage.hero.headline">{t.hero.headline}</h1>
    <p class="intro" data-i18n="contactoPage.hero.intro">{t.hero.intro}</p>
  </section>

  <section class="contact-card">
    {
      wasSubmitted && (
        <p class="success-message" role="status" data-i18n="contactoPage.form.success">
          {t.form.success}
        </p>
      )
    }

    <form
      name="contacto"
      method="POST"
      netlify
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="contacto" />

      <p class="hp-field">
        <label data-i18n="contactoPage.form.honeypotLabel">
          {t.form.honeypotLabel}
          <input name="bot-field" />
        </label>
      </p>

      <div class="field">
        <label for="nombre" data-i18n="contactoPage.form.nameLabel">{t.form.nameLabel}</label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          required
          placeholder={t.form.namePlaceholder}
          data-i18n-attr="placeholder:contactoPage.form.namePlaceholder"
        />
      </div>

      <div class="field">
        <label for="email" data-i18n="contactoPage.form.emailLabel">{t.form.emailLabel}</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder={t.form.emailPlaceholder}
          data-i18n-attr="placeholder:contactoPage.form.emailPlaceholder"
        />
      </div>

      <div class="field">
        <label for="mensaje" data-i18n="contactoPage.form.messageLabel">{t.form.messageLabel}</label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="6"
          required
          placeholder={t.form.messagePlaceholder}
          data-i18n-attr="placeholder:contactoPage.form.messagePlaceholder"
        ></textarea>
      </div>

      <button type="submit" data-i18n="contactoPage.form.submit">{t.form.submit}</button>
    </form>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    width: min(760px, 100%);
    margin: 0 auto 1.5rem;
    text-align: center;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .contact-hero h1 {
    margin: 0.55rem 0 0.9rem;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    text-wrap: balance;
  }

  .intro {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .contact-card {
    width: min(720px, 100%);
    margin: 0 auto;
    padding: clamp(1rem, 2.8vw, 1.6rem);
    border: 1px solid var(--border);
    border-radius: 0.95rem;
    background: color-mix(in srgb, var(--surface) 94%, var(--bg) 6%);
  }

  .success-message {
    margin: 0 0 1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--border));
    border-radius: 0.65rem;
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    padding: 0.75rem 0.9rem;
  }

  .hp-field {
    display: none;
  }

  form {
    display: grid;
    gap: 0.9rem;
  }

  .field {
    display: grid;
    gap: 0.4rem;
  }

  label {
    font-weight: 600;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    background: var(--surface);
    color: var(--text);
    font: inherit;
    padding: 0.7rem 0.8rem;
  }

  textarea {
    resize: vertical;
    min-height: 7rem;
  }

  input:focus-visible,
  textarea:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  button {
    width: fit-content;
    min-height: 2.8rem;
    border: 1px solid var(--primary);
    border-radius: 0.6rem;
    background: var(--primary);
    color: #fff;
    font: inherit;
    padding: 0 1.1rem;
    cursor: pointer;
  }

  button:hover {
    background: color-mix(in srgb, var(--primary) 85%, #fff 15%);
  }
  @media (max-width: 640px) {
    button {
      width: 100%;
    }
  }
</style>
