---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
  DEFAULT_LOCALE,
  LOCALE_COOKIE_KEY,
  LOCALE_STORAGE_KEY,
  messagesByLocale,
} from "../i18n/locales";

interface Props {
  title?: string;
  titleKey?: string;
}

const fallbackLocale = DEFAULT_LOCALE;
const { title = messagesByLocale[fallbackLocale].shared.siteTitle, titleKey = "shared.siteTitle" } = Astro.props;
---

<html lang={fallbackLocale} data-i18n-title={titleKey}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script
      is:inline
      define:vars={{
        LOCALE_COOKIE_KEY,
        LOCALE_STORAGE_KEY,
        DEFAULT_LOCALE: fallbackLocale,
        MESSAGES: messagesByLocale,
      }}
    >
      (() => {
        const supports = ["es", "en"];
        const normalize = (value) => {
          if (!value) return null;
          const cleanValue = value.toLowerCase().split("-")[0];
          return cleanValue === "en" ? "en" : "es";
        };

        const readPath = (source, path) => {
          return path.split(".").reduce((acc, step) => {
            if (!acc) return undefined;
            return acc[step];
          }, source);
        };

        const applyI18n = (locale) => {
          const activeLocale = supports.includes(locale) ? locale : DEFAULT_LOCALE;
          const dictionary = MESSAGES[activeLocale] ?? MESSAGES[DEFAULT_LOCALE];
          document.documentElement.setAttribute("lang", activeLocale);

          const titleKey = document.documentElement.getAttribute("data-i18n-title");
          if (titleKey) {
            const nextTitle = readPath(dictionary, titleKey);
            if (typeof nextTitle === "string") {
              document.title = nextTitle;
            }
          }

          document.querySelectorAll("[data-i18n]").forEach((element) => {
            const key = element.getAttribute("data-i18n");
            if (!key) return;
            const translatedValue = readPath(dictionary, key);
            if (typeof translatedValue === "string") {
              element.textContent = translatedValue;
            }
          });

          document.querySelectorAll("[data-i18n-attr]").forEach((element) => {
            const mapping = element.getAttribute("data-i18n-attr");
            if (!mapping) return;

            mapping.split(";").forEach((entry) => {
              const [attribute, key] = entry.split(":").map((value) => value?.trim());
              if (!attribute || !key) return;
              const translatedValue = readPath(dictionary, key);
              if (typeof translatedValue === "string") {
                element.setAttribute(attribute, translatedValue);
              }
            });
          });
        };

        const getCookie = (key) => {
          const pattern = new RegExp(`(?:^|; )${key}=([^;]*)`);
          const match = document.cookie.match(pattern);
          return match ? decodeURIComponent(match[1]) : null;
        };
        const preferredLocale =
          normalize(localStorage.getItem(LOCALE_STORAGE_KEY)) ??
          normalize(getCookie(LOCALE_COOKIE_KEY)) ??
          normalize((navigator.languages && navigator.languages[0]) || navigator.language) ??
          DEFAULT_LOCALE;

        localStorage.setItem(LOCALE_STORAGE_KEY, preferredLocale);
        document.cookie = `${LOCALE_COOKIE_KEY}=${preferredLocale}; path=/; max-age=31536000; SameSite=Lax`;

        window.addEventListener("gocapital:localechange", (event) => {
          const nextLocale = normalize(event.detail?.locale) ?? DEFAULT_LOCALE;
          localStorage.setItem(LOCALE_STORAGE_KEY, nextLocale);
          document.cookie = `${LOCALE_COOKIE_KEY}=${nextLocale}; path=/; max-age=31536000; SameSite=Lax`;
          applyI18n(nextLocale);
        });

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", () => applyI18n(preferredLocale), { once: true });
        } else {
          applyI18n(preferredLocale);
        }
      })();
    </script>
    <script is:inline>
      (() => {
        const key = "gocapital-theme";

        try {
          const storedTheme = localStorage.getItem(key);
          const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const fallbackTheme = systemPrefersDark ? "dark" : "light";
          const theme = storedTheme === "dark" || storedTheme === "light" ? storedTheme : fallbackTheme;
          document.documentElement.setAttribute("data-theme", theme);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <style is:global>
      :root,
      :root[data-theme="light"] {
        color-scheme: light;
        --bg: #f4f6f8;
        --surface: #ffffff;
        --surface-elevated: #e9eef3;
        --primary: #1b3a57;
        --accent: #c8a14a;
        --text: #1c252e;
        --muted: #5f6b7a;
        --border: #d6dee6;
        --bg-spot: #e9eef3;
        --dropdown-shadow: rgba(28, 37, 46, 0.16);
        --brand-mark-fg: #fff;
        --motion-fast: 180ms;
        --motion-medium: 320ms;
        --motion-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      }

      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #0e1117;
        --surface: #161b22;
        --surface-elevated: #1f2630;
        --primary: #1b3a57;
        --accent: #c8a14a;
        --text: #e6edf3;
        --muted: #9ba7b4;
        --border: #2b3440;
        --bg-spot: #1b3a57;
        --dropdown-shadow: rgba(0, 0, 0, 0.35);
        --brand-mark-fg: #e6edf3;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", "Helvetica Neue", Helvetica, sans-serif;
        color: var(--text);
        background: radial-gradient(circle at top right, var(--bg-spot) 0%, var(--bg) 55%);
      }

      html {
        scroll-behavior: smooth;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, var(--surface) 92%, transparent);
        border-bottom: 1px solid var(--border);
        transition:
          background-color var(--motion-fast) var(--motion-ease),
          border-color var(--motion-fast) var(--motion-ease),
          box-shadow var(--motion-fast) var(--motion-ease);
      }

      .site-header[data-scrolled="true"] {
        box-shadow: 0 8px 26px rgba(0, 0, 0, 0.14);
      }

      .header-shell {
        width: min(1100px, 100% - 2rem);
        margin: 0 auto;
        padding: 0.75rem 0;
      }

      .header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        color: inherit;
      }

      .brand-logo {
        width: clamp(8.5rem, 18vw, 11rem);
        height: auto;
        display: block;
      }

      .header-actions {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }

      .menu-toggle,
      .theme-toggle,
      .language-option {
        border: 1px solid var(--border);
        border-radius: 0.6rem;
        background: var(--surface);
        color: var(--text);
        height: 2.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font: inherit;
      }

      .menu-toggle,
      .theme-toggle {
        min-width: 2.5rem;
        padding: 0 0.75rem;
      }

      .language-switcher {
        display: inline-flex;
        border-radius: 0.6rem;
        overflow: hidden;
      }

      .language-option {
        min-width: 2.35rem;
        padding: 0 0.6rem;
        border-radius: 0;
        border-right-width: 0;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.05em;
      }

      .language-option:last-child {
        border-right-width: 1px;
      }

      .language-option[aria-pressed="true"] {
        background: color-mix(in srgb, var(--primary) 18%, var(--surface));
        color: var(--text);
      }

      .theme-toggle {
        gap: 0.45rem;
      }

      .theme-icon {
        width: 1rem;
        height: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .theme-icon svg {
        width: 1rem;
        height: 1rem;
        fill: none;
        stroke: currentColor;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      :root[data-theme="light"] .theme-icon-sun {
        display: none;
      }

      :root[data-theme="dark"] .theme-icon-moon {
        display: none;
      }

      .theme-toggle:hover,
      .menu-toggle:hover,
      .language-option:hover {
        background: var(--surface-elevated);
        transform: translateY(-1px);
      }

      a,
      button,
      input,
      textarea,
      select {
        transition:
          color var(--motion-fast) var(--motion-ease),
          background-color var(--motion-fast) var(--motion-ease),
          border-color var(--motion-fast) var(--motion-ease),
          box-shadow var(--motion-fast) var(--motion-ease),
          transform var(--motion-fast) var(--motion-ease),
          opacity var(--motion-fast) var(--motion-ease);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .menu-toggle:focus-visible,
      .theme-toggle:focus-visible,
      .language-option:focus-visible,
      .menu-link:focus-visible,
      .submenu-toggle:focus-visible,
      .submenu-link:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .main-nav {
        display: none;
        margin-top: 0.8rem;
        border: 1px solid var(--border);
        border-radius: 0.9rem;
        background: var(--surface);
        padding: 0.6rem;
      }

      .main-nav[data-open="true"] {
        display: block;
      }

      .menu-list,
      .submenu-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .menu-item + .menu-item {
        margin-top: 0.35rem;
      }

      .menu-link,
      .submenu-toggle {
        width: 100%;
        border: 0;
        border-radius: 0.55rem;
        background: transparent;
        color: var(--text);
        font: inherit;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding: 0.65rem 0.75rem;
        position: relative;
      }

      .menu-link::after,
      .submenu-toggle::after {
        content: "";
        position: absolute;
        left: 0.75rem;
        right: 0.75rem;
        bottom: 0.28rem;
        height: 2px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--accent) 85%, #fff 15%);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--motion-medium) var(--motion-ease);
      }

      .menu-link:hover,
      .submenu-toggle:hover,
      .submenu-link:hover {
        background: var(--surface-elevated);
        transform: translateY(-1px);
      }

      .menu-link:hover::after,
      .menu-link:focus-visible::after,
      .submenu-toggle:hover::after,
      .submenu-toggle:focus-visible::after {
        transform: scaleX(1);
      }

      .submenu-toggle {
        cursor: pointer;
      }

      .submenu-caret {
        transition: transform 150ms ease;
      }

      .submenu-toggle[aria-expanded="true"] .submenu-caret {
        transform: rotate(180deg);
      }

      .submenu-list {
        margin-top: 0.2rem;
        padding-left: 0.3rem;
      }

      .submenu-list[hidden] {
        display: none;
      }

      .submenu-link {
        display: block;
        color: var(--muted);
        text-decoration: none;
        border-radius: 0.45rem;
        padding: 0.55rem 0.75rem;
      }

      .main-content {
        width: min(1100px, 100% - 2rem);
        margin: 2rem auto;
      }

      .main-content > *.reveal-item {
        opacity: 0;
        transform: translateY(18px);
        transition:
          opacity 680ms var(--motion-ease),
          transform 680ms var(--motion-ease);
      }

      .main-content > *.reveal-item.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 899px) {
        .header-actions {
          gap: 0.4rem;
        }

        .language-option {
          min-width: 2.15rem;
          padding: 0 0.45rem;
        }

        .theme-label {
          display: none;
        }

        .theme-toggle {
          padding-inline: 0.65rem;
        }
      }

      @media (min-width: 900px) {
        .menu-toggle {
          display: none;
        }

        .main-nav {
          display: block;
          margin-top: 0;
          border: 0;
          border-radius: 0;
          background: transparent;
          padding: 0;
        }

        .menu-list {
          display: flex;
          align-items: center;
          gap: 0.25rem;
        }

        .menu-item {
          position: relative;
        }

        .menu-item + .menu-item {
          margin-top: 0;
        }

        .menu-link,
        .submenu-toggle {
          width: auto;
          padding-inline: 0.8rem;
        }

        .submenu-list {
          position: absolute;
          top: calc(100% + 0.35rem);
          left: 0;
          min-width: 13rem;
          background: var(--surface);
          border: 1px solid var(--border);
          border-radius: 0.7rem;
          padding: 0.3rem;
          box-shadow: 0 12px 28px var(--dropdown-shadow);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0ms !important;
          transition-duration: 0ms !important;
          scroll-behavior: auto !important;
        }

        .main-content > * {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        const mainContent = document.querySelector(".main-content");
        if (!mainContent) return;

        const sections = Array.from(mainContent.children).filter(
          (node) => !["STYLE", "SCRIPT"].includes(node.tagName)
        );
        if (!sections.length) return;

        sections.forEach((section, index) => {
          section.classList.add("reveal-item");
          section.style.transitionDelay = `${index * 70}ms`;
        });

        const revealOnScroll = () => {
          const triggerLine = window.innerHeight * 0.82;

          sections.forEach((section) => {
            if (section.classList.contains("is-visible")) return;

            const rect = section.getBoundingClientRect();
            if (rect.top <= triggerLine) {
              section.classList.add("is-visible");
            }
          });
        };

        revealOnScroll();
        window.addEventListener("scroll", revealOnScroll, { passive: true });
        window.addEventListener("resize", revealOnScroll);
      })();
    </script>
  </body>
</html>


